{
    "name": "daniel-km/omeka-s-module-derivativemedia",
    "type": "omeka-s-module",
    "description": "Module for Omeka S: Create and cache derivative files for items (zip, pdf, iiif, etc.) and optimize audio and video files for performance and cross-browser compatibility.",
    "keywords": [
        "Omeka S",
        "Omeka S module",
        "multimedia",
        "audio",
        "video",
        "pdf",
        "cross-browser compatibility"
    ],
    "license": "CECILL-2.1",
    "homepage": "https://gitlab.com/Daniel-KM/Omeka-S-module-DerivativeMedia",
    "authors": [
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.packagist@Berthereau.net"
        }
    ],
    "support": {
        "issues": "https://gitlab.com/Daniel-KM/Omeka-S-module-DerivativeMedia/-/issues",
        "forum": "https://forum.omeka.org/"
    },
    "_require (not set until Omeka S merges PR #2412)": {
        "omeka/omeka-s": "^4.1",
        "daniel-km/omeka-s-module-common": "*"
    },
    "autoload": {
        "psr-4": {
            "DerivativeMedia\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DerivativeMediaTest\\": "tests/DerivativeMediaTest/"
        }
    },
    "extra": {
        "installer-name": "DerivativeMedia",
        "configurable": true
    }
}
